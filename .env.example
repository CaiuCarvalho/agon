# Environment Variables Template
# Copie este arquivo para .env.local em cada app e ajuste os valores
#
# SECURITY NOTES:
# - NEVER commit .env files to version control
# - NEVER expose SUPABASE_SERVICE_ROLE_KEY to the frontend
# - Only NEXT_PUBLIC_* variables are accessible in client-side code
# - Supabase keys should start with 'eyJ' (JWT format)
#
# ENVIRONMENT POLICY:
# - Desenvolvimento local deve apontar para o projeto Supabase de STAGING
#   (nunca produção). Usar credenciais dos secrets STAGING_* do GitHub.
# - Mercado Pago: usar sempre token de sandbox (TEST-*) fora de produção.
# - Deploy de produção é automático a partir da branch `main`. Deploy de
#   staging é automático a partir da branch `staging`. Ver CLAUDE.md.

# ==============================================
# apps/web/.env.local
# ==============================================

# Supabase Configuration
# Get these from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ⚠️ CRITICAL: Service Role Key (SERVER-SIDE ONLY)
# This key bypasses RLS and should NEVER be exposed to the frontend
# Only use in server-side code (API routes, server components)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Mercado Pago (Payment Gateway)
# Get from: https://www.mercadopago.com.br/developers/panel/app
# 
# For DEVELOPMENT/TESTING:
# - Use TEST credentials (Access Token starts with APP_USR-)
# - Get from "Credenciais de teste" in Mercado Pago panel
# - Webhook secret is user-generated (see MERCADOPAGO-SETUP-GUIDE.md)
#
# For PRODUCTION:
# - Use PRODUCTION credentials from "Credenciais de produção"
# - Complete account activation process first
# - Use same webhook secret in both .env and Mercado Pago panel
MERCADOPAGO_ACCESS_TOKEN=APP_USR-your-access-token-here
MERCADOPAGO_WEBHOOK_SECRET=your-webhook-secret-here
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# Node Environment
# Use "development" for local, "production" for deployed
NODE_ENV=development

# Admin Panel Configuration
# Email whitelist for admin access (backend validation)
# Only users with these emails AND role='admin' can access admin panel
ADMIN_EMAIL_PRIMARY=admin@example.com
ADMIN_EMAIL_BACKUP=backup-admin@example.com

# Frontend admin guard (client-side check only, backend is authoritative)
# These should match the backend values above
NEXT_PUBLIC_ADMIN_EMAIL_PRIMARY=admin@example.com
NEXT_PUBLIC_ADMIN_EMAIL_BACKUP=backup-admin@example.com

# ==============================================
# Observabilidade (opcional — app funciona sem estas vars)
# ==============================================

# Sentry — error tracking + performance
# Criar projeto em https://sentry.io → Settings → Client Keys (DSN)
# NEXT_PUBLIC_SENTRY_DSN é exposto ao browser (client-side errors)
# SENTRY_DSN é server-only
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
# Auth token para upload de source maps no build (Settings → Auth Tokens)
SENTRY_AUTH_TOKEN=sntrys_xxx
# Org e project para CLI de source maps (visível no URL do Sentry)
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=agon-web

# Grafana Cloud — traces (OpenTelemetry / Tempo)
# Criar conta em https://grafana.com → Connections → Add new connection → OpenTelemetry
# GRAFANA_OTLP_TOKEN = Base64(instanceId:apiToken)
GRAFANA_OTLP_ENDPOINT=https://otlp-gateway-prod-us-east-0.grafana.net/otlp
GRAFANA_OTLP_TOKEN=base64(instanceId:apiToken)

# ==============================================
# apps/api/.env (se necessário)
# ==============================================
PORT=3333
NODE_ENV=production
