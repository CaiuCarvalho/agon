# Environment Variables Template
# Copie este arquivo para .env.local em cada app e ajuste os valores
#
# SECURITY NOTES:
# - NEVER commit .env files to version control
# - NEVER expose SUPABASE_SERVICE_ROLE_KEY to the frontend
# - Only NEXT_PUBLIC_* variables are accessible in client-side code
# - Supabase keys should start with 'eyJ' (JWT format)

# ==============================================
# apps/web/.env.local
# ==============================================

# Supabase Configuration
# Get these from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ⚠️ CRITICAL: Service Role Key (SERVER-SIDE ONLY)
# This key bypasses RLS and should NEVER be exposed to the frontend
# Only use in server-side code (API routes, server components)
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Resend (Email Service)
# Get from: https://resend.com/api-keys
# Optional - only needed if you want to send emails
RESEND_API_KEY=re_...

# Mercado Pago (Payment Gateway)
# Get from: https://www.mercadopago.com.br/developers/panel/app
# 
# For DEVELOPMENT/TESTING:
# - Use TEST credentials (Access Token starts with APP_USR-)
# - Get from "Credenciais de teste" in Mercado Pago panel
# - Webhook secret is user-generated (see MERCADOPAGO-SETUP-GUIDE.md)
#
# For PRODUCTION:
# - Use PRODUCTION credentials from "Credenciais de produção"
# - Complete account activation process first
# - Use same webhook secret in both .env and Mercado Pago panel
MERCADOPAGO_ACCESS_TOKEN=APP_USR-your-access-token-here
MERCADOPAGO_WEBHOOK_SECRET=your-webhook-secret-here
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cloudinary (Image Upload Service)
# Get from: https://console.cloudinary.com/
# Optional - only needed for product image uploads in admin
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# Node Environment
# Use "development" for local, "production" for deployed
NODE_ENV=development

# Admin Panel Configuration
# Email whitelist for admin access (backend validation)
# Only users with these emails AND role='admin' can access admin panel
ADMIN_EMAIL_PRIMARY=admin@example.com
ADMIN_EMAIL_BACKUP=backup-admin@example.com

# Frontend admin guard (client-side check only, backend is authoritative)
# These should match the backend values above
NEXT_PUBLIC_ADMIN_EMAIL_PRIMARY=admin@example.com
NEXT_PUBLIC_ADMIN_EMAIL_BACKUP=backup-admin@example.com

# ==============================================
# apps/api/.env (se necessário)
# ==============================================
PORT=3333
NODE_ENV=production
